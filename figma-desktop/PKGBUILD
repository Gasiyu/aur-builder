pkgname=figma-desktop
pkgver=126.2.10
pkgrel=1
pkgdesc='Figma Desktop for Linux'
arch=('x86_64')
url='https://github.com/IliyaBrook/figma-linux'
license=('custom:Proprietary')
depends=()
makedepends=(
	'7zip'
	'curl'
	'imagemagick'
	'nodejs>=20'
	'npm'
	'wget'
)
options=('!strip')

_tag="figma-desktop_${pkgver}"
_srcdir="figma-linux-${_tag}"

source=(
	"${pkgname}-${pkgver}.tar.gz::${url}/archive/refs/tags/${_tag}.tar.gz"
	"Figma-${pkgver}-full.nupkg::https://desktop.figma.com/win/build/Figma-${pkgver}-full.nupkg"
)
sha256sums=(
	'a1f16da9298f3c67bbe49b9697f09ca80633f0ef5ada7e4ce5db2f4c719ffea2'
	'84947e19ffacba9421cdd538ef764c48da9f6f9e799bb19dc2527cb3dd285917'
)

build() {
	cd "${srcdir}/${_srcdir}"

	export HOME="${srcdir}/build-home"
	export npm_config_cache="${srcdir}/npm-cache"
	mkdir -p "${HOME}" "${npm_config_cache}"

	./build.sh --build staging --clean no --nupkg "${srcdir}/Figma-${pkgver}-full.nupkg"
}

package() {
	cd "${srcdir}/${_srcdir}"

	local install_root="${pkgdir}/usr/lib/${pkgname}"
	local staging_dir="${PWD}/build/electron-app"
	local resources_dir="${install_root}/node_modules/electron/dist/resources"

	install -dm755 "${pkgdir}/usr/bin" \
		"${pkgdir}/usr/share/applications" \
		"${install_root}"

	cp -a "${staging_dir}/node_modules" "${install_root}/"
	install -Dm644 "${staging_dir}/app.asar" "${resources_dir}/app.asar"
	if [[ -d ${staging_dir}/app.asar.unpacked ]]; then
		cp -a "${staging_dir}/app.asar.unpacked" "${resources_dir}/"
	fi

	install -Dm644 scripts/launcher-common.sh "${install_root}/launcher-common.sh"

	for size in 16 24 32 48 64 128 256; do
		local icon_source_path=''
		icon_source_path=$(find build -maxdepth 1 -name 'figma_*.png' -exec identify -format '%w %h %i\n' {} \; 2>/dev/null | awk -v s="$size" '$1 == s && $2 == s { print $3; exit }')
		if [[ -f ${icon_source_path} ]]; then
			install -Dm644 "${icon_source_path}" "${pkgdir}/usr/share/icons/hicolor/${size}x${size}/apps/${pkgname}.png"
		fi
	done

	install -Dm755 /dev/stdin "${pkgdir}/usr/bin/${pkgname}" <<'EOF'
#!/usr/bin/env bash

source "/usr/lib/figma-desktop/launcher-common.sh"

setup_logging || exit 1
setup_electron_env

log_message '--- Figma Desktop Launcher Start ---'
log_message "Timestamp: $(date)"
log_message "Arguments: $@"

if ! check_display; then
	log_message 'No display detected (TTY session)'
	echo 'Error: Figma Desktop requires a graphical desktop environment.' >&2
	echo 'Please run from within an X11 or Wayland session, not from a TTY.' >&2
	exit 1
fi

detect_display_backend
if [[ $is_wayland == true ]]; then
	log_message 'Wayland detected'
fi

electron_exec='electron'
local_electron_path="/usr/lib/figma-desktop/node_modules/electron/dist/electron"
if [[ -f $local_electron_path ]]; then
	electron_exec="$local_electron_path"
	log_message "Using local Electron: $electron_exec"
else
	if command -v electron &> /dev/null; then
		log_message "Using global Electron: $electron_exec"
	else
		log_message 'Error: Electron executable not found'
		if command -v zenity &> /dev/null; then
			zenity --error --text='Figma Desktop cannot start because the Electron framework is missing.'
		elif command -v kdialog &> /dev/null; then
			kdialog --error 'Figma Desktop cannot start because the Electron framework is missing.'
		fi
		exit 1
	fi
fi

app_path="/usr/lib/figma-desktop/node_modules/electron/dist/resources/app.asar"

build_electron_args 'deb'
electron_args+=("$app_path")

app_dir="/usr/lib/figma-desktop"
log_message "Changing directory to $app_dir"
cd "$app_dir" || {
	log_message "Failed to cd to $app_dir"
	exit 1
}

log_message "Executing: $electron_exec ${electron_args[*]} $*"
"$electron_exec" "${electron_args[@]}" "$@" >> "$log_file" 2>&1
exit_code=$?
log_message "Electron exited with code: $exit_code"
log_message '--- Figma Desktop Launcher End ---'
exit $exit_code
EOF

	install -Dm644 /dev/stdin "${pkgdir}/usr/share/applications/${pkgname}.desktop" <<'EOF'
[Desktop Entry]
Name=Figma
Exec=/usr/bin/figma-desktop %u
Icon=figma-desktop
Type=Application
Terminal=false
Categories=Graphics;Development;
MimeType=x-scheme-handler/figma;
StartupWMClass=Figma
Comment=Figma Desktop for Linux
EOF

	if [[ -f ${install_root}/node_modules/electron/dist/chrome-sandbox ]]; then
		chmod 4755 "${install_root}/node_modules/electron/dist/chrome-sandbox"
	fi
}
